<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NSANE-RUNNER — Crash Bandicoot Endless Runner</title>
    <meta name="description"
        content="An endless runner game inspired by Crash Bandicoot. Choose your character and difficulty and run!">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bangers&family=Outfit:wght@400;600;700;900&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>

<body>

    <div id="splash-screen">
        <div class="splash-glow-ring"></div>

        <div class="menu-wrapper">

            <header class="menu-header">
                <p class="splash-subtitle">Bandicoot Edition</p>
                <h1 class="splash-title">NSANE<br>RUNNER</h1>
                <div class="splash-divider"></div>
            </header>

            <div class="mesh-placeholder" id="character-mesh-container">
                [ 3D Character Mesh Viewport ]
            </div>

            <section class="menu-section" id="section-character">
                <div class="menu-cards" id="character-cards">
                    <button class="menu-card" data-group="character" data-value="crash" id="card-crash">
                        <div class="card-icon-wrap crash-icon">
                            <span class="card-emoji">🦊</span>
                        </div>
                        <span class="card-name">Crash Bandicoot</span>
                        <div class="card-check">✓</div>
                    </button>
                    <button class="menu-card" data-group="character" data-value="cortex" id="card-cortex">
                        <div class="card-icon-wrap cortex-icon">
                            <span class="card-emoji">🧪</span>
                        </div>
                        <span class="card-name">Dr. Neo Cortex</span>
                        <div class="card-check">✓</div>
                    </button>
                </div>
            </section>

            <section class="menu-section" id="section-difficulty">
                <div class="menu-cards menu-cards--triple" id="difficulty-cards">
                    <button class="menu-card card--easy" data-group="difficulty" data-value="easy" id="card-easy">
                        <span class="card-name">Easy</span>
                        <div class="card-check">✓</div>
                    </button>
                    <button class="menu-card card--medium" data-group="difficulty" data-value="medium" id="card-medium">
                        <span class="card-name">Medium</span>
                        <div class="card-check">✓</div>
                    </button>
                    <button class="menu-card card--hard" data-group="difficulty" data-value="nsane" id="card-hard">
                        <span class="card-name">N. Sane!</span>
                        <div class="card-check">✓</div>
                    </button>
                </div>
            </section>

            <button class="commands-btn" id="btn-commands">
                📖 How to Play
            </button>

            <p class="menu-error hidden" id="menu-error">
                ⚠️ Please complete your selections before playing!
            </p>

            <button class="play-btn" id="play-btn">
                <span class="play-btn-text">Play Game</span>
                <span class="play-btn-icon">▶</span>
            </button>

        </div>
    </div>
    <script type="module" src="/main.js"></script>

    <script>
        // ---- MENU SELECTION LOGIC ----
        (function () {
            const selections = { character: null, map: null, difficulty: null };

            // Handle card clicks
            document.querySelectorAll('.menu-card').forEach(card => {
                card.addEventListener('click', () => {
                    const group = card.dataset.group;
                    const value = card.dataset.value;

                    // Deselect siblings in the same group
                    document.querySelectorAll(`.menu-card[data-group="${group}"]`).forEach(c => {
                        c.classList.remove('selected');
                    });

                    // Select this card
                    card.classList.add('selected');
                    selections[group] = value;

                    // Hide error message if all selections are made
                    if (selections.character && selections.map && selections.difficulty) {
                        document.getElementById('menu-error').classList.add('hidden');
                    }
                });
            });

            // Play button handler
            document.getElementById('play-btn').addEventListener('click', () => {
                if (!selections.character || !selections.map || !selections.difficulty) {
                    const errEl = document.getElementById('menu-error');
                    errEl.classList.remove('hidden');
                    // Shake animation
                    errEl.classList.remove('shake');
                    void errEl.offsetWidth;
                    errEl.classList.add('shake');
                    return;
                }

                // Save selections to localStorage
                localStorage.setItem('nsane_character', selections.character);
                localStorage.setItem('nsane_map', selections.map);
                localStorage.setItem('nsane_difficulty', selections.difficulty);

                // Dispatch a custom event so main.js can pick it up
                window.dispatchEvent(new CustomEvent('nsane-play'));

                // Fade out splash screen
                const splash = document.getElementById('splash-screen');
                if (splash) splash.classList.add('hidden');
            });
        })();
    </script>
</body>

</html>


* { margin: 0; padding: 0; box-sizing: border-box; }

body {
overflow: hidden;
background-color: #0a0a0f;
font-family: 'Outfit', sans-serif;
}

canvas { display: block; width: 100vw; height: 100vh; }

/* ===================== SPLASH / MENU SCREEN ===================== */
#splash-screen {
position: fixed;
inset: 0;
z-index: 100;
display: flex;
flex-direction: column;
align-items: center;
justify-content: flex-start;
background: radial-gradient(ellipse at center, #1a0533 0%, #0a0a0f 70%);
transition: opacity 0.8s ease, visibility 0.8s ease;
overflow-y: auto;
overflow-x: hidden;
}

#splash-screen.hidden {
opacity: 0;
visibility: hidden;
pointer-events: none;
}

/* Animated star field */
#splash-screen::before {
content: '';
position: fixed;
inset: 0;
pointer-events: none;
background-image:
radial-gradient(1px 1px at 10% 15%, rgba(255,255,255,0.6) 0%, transparent 100%),
radial-gradient(1px 1px at 30% 40%, rgba(255,255,255,0.4) 0%, transparent 100%),
radial-gradient(1px 1px at 55% 20%, rgba(255,255,255,0.7) 0%, transparent 100%),
radial-gradient(1px 1px at 75% 60%, rgba(255,255,255,0.5) 0%, transparent 100%),
radial-gradient(1px 1px at 90% 10%, rgba(255,255,255,0.6) 0%, transparent 100%),
radial-gradient(1px 1px at 20% 80%, rgba(255,255,255,0.4) 0%, transparent 100%),
radial-gradient(1px 1px at 65% 85%, rgba(255,255,255,0.5) 0%, transparent 100%);
animation: twinkle 4s ease-in-out infinite alternate;
}

@keyframes twinkle {
0% { opacity: 0.5; }
100% { opacity: 1; }
}

.splash-glow-ring {
position: fixed;
top: 50%;
left: 50%;
transform: translate(-50%, -50%);
width: 600px;
height: 600px;
border-radius: 50%;
background: radial-gradient(circle, rgba(255, 130, 0, 0.10) 0%, transparent 70%);
animation: pulse-ring 3s ease-in-out infinite;
pointer-events: none;
}

@keyframes pulse-ring {
0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.6; }
50% { transform: translate(-50%, -50%) scale(1.15); opacity: 1; }
}

/* ===================== MENU WRAPPER ===================== */
.menu-wrapper {
position: relative;
z-index: 1;
width: 100%;
max-width: 740px;
padding: 30px 24px 60px;
display: flex;
flex-direction: column;
align-items: center;
gap: 20px;
}

/* ---------- HEADER ---------- */
.menu-header {
text-align: center;
margin-bottom: 0;
}

.splash-subtitle {
font-weight: 700;
font-size: 0.85rem;
letter-spacing: 0.5em;
color: #ff8c00;
text-transform: uppercase;
margin-bottom: 8px;
opacity: 0.9;
}

.splash-title {
font-family: 'Bangers', cursive;
font-size: clamp(2.5rem, 6vw, 4rem);
letter-spacing: 0.06em;
line-height: 0.9;
background: linear-gradient(180deg, #ffffff 0%, #ffd26b 50%, #ff8c00 100%);
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
background-clip: text;
filter: drop-shadow(0 0 20px rgba(255, 140, 0, 0.5));
animation: title-bob 3s ease-in-out infinite;
}

@keyframes title-bob {
0%, 100% { transform: translateY(0px) rotate(-1deg); }
50% { transform: translateY(-4px) rotate(1deg); }
}

/* ===================== MESH CONTAINER ===================== */
.mesh-placeholder {
width: 100%;
height: 260px;
border: 2px dashed rgba(255, 140, 0, 0.3);
border-radius: 16px;
background: radial-gradient(circle, rgba(255, 140, 0, 0.05) 0%, rgba(0, 0, 0, 0.4) 100%);
display: flex;
align-items: center;
justify-content: center;
color: rgba(255, 255, 255, 0.25);
font-weight: 600;
letter-spacing: 0.1em;
text-transform: uppercase;
font-size: 0.9rem;
box-shadow: inset 0 0 30px rgba(0, 0, 0, 0.5);
animation: fadeSlideUp 0.6s ease-out both;
}

/* ===================== MENU SECTIONS ===================== */
.menu-section {
width: 100%;
animation: fadeSlideUp 0.6s ease-out both;
}

#section-character { animation-delay: 0.1s; }
#section-difficulty{ animation-delay: 0.2s; }

@keyframes fadeSlideUp {
from { opacity: 0; transform: translateY(20px); }
to { opacity: 1; transform: translateY(0); }
}

/* ===================== CARDS GRID ===================== */
.menu-cards {
display: grid;
grid-template-columns: repeat(2, 1fr);
gap: 14px;
}

.menu-cards--triple {
grid-template-columns: repeat(3, 1fr);
}

/* ===================== INDIVIDUAL CARD ===================== */
.menu-card {
position: relative;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
gap: 8px;
padding: 16px 14px;
border-radius: 16px;
border: 2px solid rgba(255, 255, 255, 0.08);
background: rgba(255, 255, 255, 0.04);
backdrop-filter: blur(12px);
cursor: pointer;
transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
outline: none;
color: #fff;
font-family: 'Outfit', sans-serif;
overflow: hidden;
}

.menu-card::before {
content: '';
position: absolute;
inset: 0;
border-radius: 14px;
background: linear-gradient(135deg, rgba(255,140,0,0.06) 0%, transparent 60%);
opacity: 0;
transition: opacity 0.3s ease;
}

.menu-card:hover {
border-color: rgba(255, 140, 0, 0.35);
background: rgba(255, 255, 255, 0.07);
transform: translateY(-3px);
box-shadow: 0 8px 30px rgba(255, 140, 0, 0.12);
}

.menu-card:hover::before {
opacity: 1;
}

.menu-card.selected {
border-color: #ff8c00;
background: rgba(255, 140, 0, 0.12);
box-shadow: 0 0 20px rgba(255, 140, 0, 0.25), inset 0 0 20px rgba(255, 140, 0, 0.05);
transform: translateY(-3px) scale(1.02);
}

.menu-card.selected::before {
opacity: 1;
}

/* Checkmark */
.card-check {
position: absolute;
top: 10px;
right: 10px;
width: 22px;
height: 22px;
border-radius: 50%;
background: #ff8c00;
color: #0a0a0f;
font-size: 0.75rem;
font-weight: 900;
display: flex;
align-items: center;
justify-content: center;
opacity: 0;
transform: scale(0.5);
transition: all 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.menu-card.selected .card-check {
opacity: 1;
transform: scale(1);
}

/* Card icon area */
.card-icon-wrap {
width: 48px;
height: 48px;
border-radius: 50%;
display: flex;
align-items: center;
justify-content: center;
flex-shrink: 0;
transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.menu-card:hover .card-icon-wrap,
.menu-card.selected .card-icon-wrap {
transform: scale(1.1);
}

.card-emoji {
font-size: 1.4rem;
line-height: 1;
}

.crash-icon { background: radial-gradient(circle at 35% 35%, #ff9e2c, #c84b00); box-shadow: 0 0 14px
rgba(255,140,0,0.3); }
.cortex-icon { background: radial-gradient(circle at 35% 35%, #a78bfa, #5b21b6); box-shadow: 0 0 14px
rgba(167,139,250,0.3); }

.card-name {
font-weight: 700;
font-size: 0.95rem;
letter-spacing: 0.04em;
text-align: center;
}

/* ===================== COMMANDS BUTTON ===================== */
.commands-btn {
background: transparent;
color: rgba(255, 255, 255, 0.7);
border: 1px solid rgba(255, 255, 255, 0.2);
padding: 8px 24px;
border-radius: 20px;
font-family: 'Outfit', sans-serif;
font-size: 0.8rem;
text-transform: uppercase;
letter-spacing: 0.1em;
cursor: pointer;
transition: all 0.3s ease;
animation: fadeSlideUp 0.6s ease-out 0.3s both;
}

.commands-btn:hover {
background: rgba(255, 255, 255, 0.1);
color: #fff;
border-color: rgba(255, 255, 255, 0.5);
}

/* ===================== ERROR MESSAGE ===================== */
.menu-error {
font-size: 0.85rem;
font-weight: 600;
color: #f87171;
text-align: center;
letter-spacing: 0.04em;
padding: 10px 20px;
border-radius: 10px;
background: rgba(248, 113, 113, 0.08);
border: 1px solid rgba(248, 113, 113, 0.25);
}

.menu-error.hidden { display: none; }

@keyframes shake {
0%, 100% { transform: translateX(0); }
20% { transform: translateX(-8px); }
40% { transform: translateX(8px); }
60% { transform: translateX(-6px); }
80% { transform: translateX(6px); }
}

.menu-error.shake { animation: shake 0.45s ease; }

/* ===================== PLAY BUTTON ===================== */
.play-btn {
position: relative;
display: flex;
align-items: center;
justify-content: center;
gap: 12px;
width: 100%;
max-width: 320px;
padding: 16px 32px;
border: none;
border-radius: 60px;
font-family: 'Bangers', cursive;
font-size: 1.6rem;
letter-spacing: 0.1em;
color: #0a0a0f;
cursor: pointer;
background: linear-gradient(135deg, #ffd26b 0%, #ff8c00 50%, #ff5e00 100%);
box-shadow: 0 4px 20px rgba(255, 140, 0, 0.4), 0 0 40px rgba(255, 140, 0, 0.15);
transition: all 0.3s ease;
animation: fadeSlideUp 0.6s ease-out 0.4s both;
overflow: hidden;
}

.play-btn::before {
content: '';
position: absolute;
inset: 0;
border-radius: 60px;
background: linear-gradient(135deg, transparent 30%, rgba(255,255,255,0.3) 50%, transparent 70%);
transform: translateX(-100%);
transition: transform 0.5s ease;
}

.play-btn:hover {
transform: translateY(-2px) scale(1.03);
box-shadow: 0 8px 30px rgba(255, 140, 0, 0.55), 0 0 50px rgba(255, 140, 0, 0.2);
}

.play-btn:hover::before { transform: translateX(100%); }
.play-btn:active { transform: translateY(0) scale(0.98); }

.play-btn-text, .play-btn-icon {
position: relative;
z-index: 1;
}

.play-btn-icon {
font-size: 1.2rem;
transition: transform 0.3s ease;
}

.play-btn:hover .play-btn-icon { transform: translateX(4px); }


/* ===================== RESPONSIVE ===================== */
@media (max-width: 600px) {
.menu-wrapper {
padding: 20px 16px 40px;
gap: 16px;
}

.mesh-placeholder { height: 200px; }

.menu-cards--triple {
grid-template-columns: 1fr;
}

.menu-cards {
grid-template-columns: 1fr;
}

.splash-title {
font-size: clamp(2rem, 10vw, 3.5rem);
}

.play-btn { max-width: 100%; }
}

@media (min-width: 601px) and (max-width: 800px) {
.menu-cards--triple { grid-template-columns: repeat(3, 1fr); }
.menu-cards { grid-template-columns: repeat(2, 1fr); }
}